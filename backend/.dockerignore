# Keep the build context lean: never ship caches, tests, or local virtualenvs
# into the runtime image.

# Tests and fixtures are not needed at runtime.
tests/

# Python build / cache artefacts.
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments.
.venv/
venv/

# Editor / OS metadata.
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp

# Source-control metadata.
.git/
.gitignore
.gitattributes

# Configuration that has no place in the runtime image.
# README.md is required by pyproject.toml `readme = "README.md"` so it
# stays in the build context; the wheel build needs to read it.
docker-compose*.yml

# Local databases and env files.
*.sqlite
*.db
.env
.env.*
