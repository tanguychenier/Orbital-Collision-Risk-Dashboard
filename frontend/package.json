{
  "name": "orbital-conjunctions-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b --force && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc -b --force",
    "lint": "eslint . --ext .ts,.vue,.js,.cjs,.mjs --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.vue,.js,.cjs,.mjs --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@primevue/themes": "^4.2.5",
    "@tanstack/vue-query": "^5.100.8",
    "axios": "^1.7.9",
    "cesium": "^1.141.0",
    "echarts": "^6.0.0",
    "pinia": "^2.3.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.2.5",
    "vue": "^3.5.13",
    "vue-i18n": "^11.0.1",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4.0.0-beta.7",
    "@tailwindcss/vite": "^4.0.0-beta.7",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.1.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "msw": "^2.7.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0-beta.7",
    "tailwindcss-primeui": "^0.6.1",
    "typescript": "~5.9.3",
    "vite": "^6.0.6",
    "vite-plugin-cesium": "^1.2.23",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.2.0"
  },
  "lint-staged": {
    "*.{ts,vue,js,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
