# Copy to .env and adjust as needed.

# PostgreSQL
POSTGRES_USER=ocrd
POSTGRES_PASSWORD=ocrd
POSTGRES_DB=ocrd

# Exposed ports on the host
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Where the frontend reaches the backend (from the user's browser)
VITE_API_BASE_URL=http://localhost:8000/api

# In production, set MSW=false (default). Set to true to demo without backend.
VITE_USE_MSW=false
